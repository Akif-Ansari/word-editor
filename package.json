{
  "name": "@myexamly/word-editor",
  "version": "0.0.4",
  "description": "A feature-rich Word-like rich text editor built with Slate.js, React and Tailwind CSS",
  "author": "Examly",
  "license": "MIT",
  "type": "module",
  "main": "./dist/examly-editor.umd.cjs",
  "module": "./dist/examly-editor.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/examly-editor.js",
      "require": "./dist/examly-editor.umd.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "rich-text-editor",
    "slate",
    "slate-react",
    "word-editor",
    "wysiwyg",
    "react",
    "examly-editor"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "tsc -b && vite build --mode lib",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepublishOnly": "npm run build:lib"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "slate": ">=0.100.0",
    "slate-history": ">=0.100.0",
    "slate-react": ">=0.100.0"
  },
  "dependencies": {
    "docx": "^9.6.1",
    "dompurify": "^3.4.0",
    "html-docx-js": "^0.3.1",
    "lucide-react": "^1.8.0",
    "mammoth": "^1.12.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.3",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "slate": "^0.124.1",
    "slate-history": "^0.113.1",
    "slate-react": "^0.124.0",
    "tailwindcss": "^4.2.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9",
    "vite-plugin-dts": "^4.5.4"
  }
}
